      "isDeleted": false,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "But a human manager is slow and\ncentralized. So Maestro makes the\nmanager a SMART CONTRACT — autonomous,\nunstoppable, no keeper, no bot.",
      "fontSize": 15,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 15,
      "containerId": null,
      "originalText": "But a human manager is slow and\ncentralized. So Maestro makes the\nmanager a SMART CONTRACT — autonomous,\nunstoppable, no keeper, no bot.",
      "lineHeight": 1.25,
      "autoResize": true
    },
