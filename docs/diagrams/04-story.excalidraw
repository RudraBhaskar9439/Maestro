    },
    {
      "id": "el1805111040",
      "type": "text",
      "x": 64,
      "y": 236,
      "width": 1245.75,
      "height": 21,
      "angle": 0,
      "strokeColor": "#212529",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 716526336,
      "version": 1,
      "versionNonce": 545163008,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "A liquidity pool sits still while the\nprice moves. Arbitrageurs skim the gap\n(LVR) and LPs are left with impermanent\nloss. No one is steering the pool.",
      "fontSize": 15,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 15,
      "containerId": null,
      "originalText": "A liquidity pool sits still while the\nprice moves. Arbitrageurs skim the gap\n(LVR) and LPs are left with impermanent\nloss. No one is steering the pool.",
      "lineHeight": 1.25,
      "autoResize": true
    },
