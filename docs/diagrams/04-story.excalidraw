      "updated": 1,
      "link": null,
      "locked": false,
      "text": "The auction",
      "fontSize": 22,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 22,
      "containerId": null,
