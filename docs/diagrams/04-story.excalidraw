      "isDeleted": false,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Liquidity that follows the price by\nitself. Arbitrage value recaptured as LP\nincome. Two open am-AMM problems —\nconcentrated liquidity + an autonomous\nmanager — solved.",
      "fontSize": 15,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 15,
      "containerId": null,
      "originalText": "Liquidity that follows the price by\nitself. Arbitrage value recaptured as LP\nincome. Two open am-AMM problems —\nconcentrated liquidity + an autonomous\nmanager — solved.",
      "lineHeight": 1.25,
      "autoResize": true
    },
