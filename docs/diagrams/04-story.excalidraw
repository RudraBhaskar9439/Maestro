    {
      "id": "el1842044160",
      "type": "text",
      "x": 944,
      "y": 626,
      "width": 1600.5000000000002,
      "height": 21,
      "angle": 0,
      "strokeColor": "#212529",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 602720512,
      "version": 1,
      "versionNonce": 1729086720,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "A Pyth price update on Ethereum Sepolia\nwakes our Reactive contract on Lasna. It\npicks the new tick band and fires a\ncross-chain callback to Unichain, which\nrepositions the pool — automatically.",
      "fontSize": 15,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 15,
      "containerId": null,
      "originalText": "A Pyth price update on Ethereum Sepolia\nwakes our Reactive contract on Lasna. It\npicks the new tick band and fires a\ncross-chain callback to Unichain, which\nrepositions the pool — automatically.",
      "lineHeight": 1.25,
      "autoResize": true
    },
