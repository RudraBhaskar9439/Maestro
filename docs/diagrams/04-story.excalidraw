    },
    {
      "id": "el27722304",
      "type": "text",
      "x": 944,
      "y": 236,
      "width": 1344.75,
      "height": 21,
      "angle": 0,
      "strokeColor": "#212529",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 340501880,
      "version": 1,
      "versionNonce": 594555968,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Anyone bids a per-block rent to become\nmanager. Each bid must beat the last;\nthe winner takes over after a 10-block\ndelay, then pays rent every block until\noutbid.",
      "fontSize": 15,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 15,
      "containerId": null,
      "originalText": "Anyone bids a per-block rent to become\nmanager. Each bid must beat the last;\nthe winner takes over after a 10-block\ndelay, then pays rent every block until\noutbid.",
      "lineHeight": 1.25,
      "autoResize": true
    },
