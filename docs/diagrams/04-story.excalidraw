      "updated": 1,
      "link": null,
      "locked": false,
      "text": "The problem",
      "fontSize": 22,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 22,
      "containerId": null,
      "originalText": "The problem",
