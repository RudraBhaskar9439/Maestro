      "updated": 1,
      "link": null,
      "locked": false,
      "text": "The manager's job",
      "fontSize": 22,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 22,
      "containerId": null,
      "originalText": "The manager's job",
      "lineHeight": 1.25,
      "autoResize": true
    },
    {
      "id": "el1869669376",
      "type": "text",
      "x": 1384,
      "y": 236,
      "width": 1377.75,
      "height": 21,
      "angle": 0,
      "strokeColor": "#212529",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 814302208,
      "version": 1,
      "versionNonce": 355083264,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "The manager concentrates liquidity\naround the live price and sets the swap\nfee. Better placement -> more fees ->\nworth the rent. The arbitrageur now\nworks for the LPs.",
      "fontSize": 15,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 15,
      "containerId": null,
      "originalText": "The manager concentrates liquidity\naround the live price and sets the swap\nfee. Better placement -> more fees ->\nworth the rent. The arbitrageur now\nworks for the LPs.",
      "lineHeight": 1.25,
      "autoResize": true
    },
